{
    "exercise_name": "air_squat",

    "category": "strength",

    "primary_muscles": [
        "quadriceps",
        "glutes"
    ],

    "secondary_muscles": [
        "hamstrings",
        "core",
        "calves"
    ],

    "camera_view": [
        "side",
        "front"
    ],

    "required_landmarks": [
        "left_hip",
        "right_hip",
        "left_knee",
        "right_knee",
        "left_ankle",
        "right_ankle",
        "left_shoulder",
        "right_shoulder"
    ],

    "angle_rules": {

        "knee": {
            "joint": "left_knee",

            "landmarks": [
                "left_hip",
                "left_knee",
                "left_ankle"
            ],

            "rom": {
                "min": 90,
                "max": 170
            }
        },

        "hip": {
            "joint": "left_hip",

            "landmarks": [
                "left_shoulder",
                "left_hip",
                "left_knee"
            ],

            "rom": {
                "min": 70,
                "max": 170
            }
        }
    },

    "movement": {

        "primary_axis": "vertical",

        "direction": {

            "down_phase": {
                "knee_angle": "decreasing"
            },

            "up_phase": {
                "knee_angle": "increasing"
            }
        }
    },

    "repetition": {

        "tracking_joint": "left_knee",

        "start_condition": {
            "angle": 170,
            "operator": ">="
        },

        "bottom_condition": {
            "angle": 90,
            "operator": "<="
        },

        "threshold": 15,

        "completion_condition": {
            "return_to_start": true
        }
    },

    "form_errors": {

        "insufficient_depth": {

            "threshold": 100,

            "feedback": "Lower your body more"
        },

        "knee_alignment": {

            "check": "knee_inside_foot",

            "severity": "medium",

            "feedback": "Keep knees aligned with toes"
        }
    },

    "feedback_messages": {

        "good_rep": [
            "Great repetition",
            "Perfect form"
        ],

        "bad_rep": [
            "Fix your knee position",
            "Control your movement"
        ]
    }
}